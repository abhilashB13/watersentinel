{
  "expo": {
    "name": "WaterSentinel",
    "slug": "watersentinel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1565C0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.watersentinel.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1565C0"
      },
      "package": "com.watersentinel.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow WaterSentinel to access your photos to analyse water colour and clarity.",
          "cameraPermission": "Allow WaterSentinel to take photos of your water sample for analysis."
        }
      ]
    ]
  }
}
